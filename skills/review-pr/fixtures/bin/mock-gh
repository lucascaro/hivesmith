#!/usr/bin/env bash
# Stand-in for `gh`. Routes the subset of commands the review-pr skill uses
# to the active fixture case dir (FIXTURE_DIR env var).
set -euo pipefail

if [ -z "${FIXTURE_DIR:-}" ]; then
  echo "mock-gh: FIXTURE_DIR not set" >&2
  exit 2
fi
if [ ! -d "$FIXTURE_DIR" ]; then
  echo "mock-gh: FIXTURE_DIR=$FIXTURE_DIR does not exist" >&2
  exit 2
fi

cmd="${1:-}"; sub="${2:-}"

case "$cmd $sub" in
  "pr diff")
    cat "$FIXTURE_DIR/pr.patch"
    ;;
  "pr view")
    # Ignore --json filtering — return the whole meta blob. Skill reads what it
    # needs. Real `gh` would project; the difference is harmless here.
    cat "$FIXTURE_DIR/meta.json"
    ;;
  "api graphql")
    # Only the reviewThreads query is mocked. Answering every GraphQL query with
    # a threads payload would silently feed a wrong shape to any future query the
    # skill adds, so anything else is an explicit failure.
    if ! printf '%s\n' "$@" | grep -q 'reviewThreads'; then
      echo "mock-gh: unmocked graphql query (only reviewThreads is supported)" >&2
      exit 64
    fi
    if [ -f "$FIXTURE_DIR/threads.json" ]; then
      cat "$FIXTURE_DIR/threads.json"
    else
      printf '%s\n' '{"data":{"repository":{"pullRequest":{"reviewThreads":{"pageInfo":{"hasNextPage":false,"endCursor":null},"nodes":[]}}}}}'
    fi
    ;;
  *)
    echo "mock-gh: unsupported command: $*" >&2
    exit 64
    ;;
esac
