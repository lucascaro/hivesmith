#!/usr/bin/env bash
# Set up the env for one fixture case and print instructions.
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: run-case <case-name>" >&2
  exit 64
fi

CASE="$1"
HERE="$(cd "$(dirname "$0")/.." && pwd)"
CASE_DIR="$HERE/cases/$CASE"

if [ ! -d "$CASE_DIR" ]; then
  echo "run-case: no such case: $CASE" >&2
  echo "available:" >&2
  ls "$HERE/cases" >&2
  exit 1
fi

for f in pr.patch meta.json expected.yaml; do
  if [ ! -f "$CASE_DIR/$f" ]; then
    echo "run-case: missing $CASE_DIR/$f" >&2
    exit 1
  fi
done

cat <<EOF
Case:        $CASE
Fixture dir: $CASE_DIR
Snapshot:    $CASE_DIR/snapshot

To run the skill against this case in your shell:

  export FIXTURE_DIR="$CASE_DIR"
  export PATH="$HERE/bin:\$PATH"
  cd "$CASE_DIR/snapshot"

Then in Claude Code, invoke:

  /review-pr 1

The skill will call \`gh\`, which routes to mock-gh, which reads from
FIXTURE_DIR. Save the final JSON findings array Claude produces to a file
(e.g. /tmp/$CASE.json), then:

  $HERE/bin/grade $CASE /tmp/$CASE.json
EOF
